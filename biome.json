{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              {
                "type": false,
                "source": [
                  "react",
                  "next/**",
                  ":PACKAGE:",
                  ":NODE:",
                  ":BUN:",
                  ":URL:"
                ]
              },
              ":BLANK_LINE:",
              {
                "type": false,
                "source": [
                  "./**",
                  "../**",
                  "!**/utils",
                  "!**/utils/**",
                  "!**/*.scss",
                  "!**/*.css"
                ]
              },
              ":BLANK_LINE:",
              {
                "type": false,
                "source": ["**/utils", "**/utils/**", "../utils", "./utils"]
              },
              ":BLANK_LINE:",
              { "type": true },
              ":BLANK_LINE:",
              {
                "type": false,
                "source": ["**/*.scss", "**/*.css", "**/sass/**"]
              }
            ]
          }
        }
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noSvgWithoutTitle": "off"
      },
      "performance": {
        "noImgElement": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all"
    }
  }
}
