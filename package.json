{
  "name": "jcvegab-portfolio",
  "version": "1.0.0",
  "description": "Personal portfolio and blog for Joseph Vega, built with Next.js static export, React, TypeScript and Markdown content.",
  "keywords": [
    "blog",
    "content-driven",
    "frontend",
    "jamstack",
    "markdown",
    "nextjs",
    "portfolio",
    "react",
    "scss",
    "static-export",
    "static-site",
    "typescript",
    "vitest"
  ],
  "author": "Joseph Vega <admin@jcvegab.dev>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/jcvegab/jcvegab-portfolio.git"
  },
  "bugs": {
    "url": "https://github.com/jcvegab/jcvegab-portfolio/issues"
  },
  "homepage": "https://jcvegab.dev",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbo",
    "develop": "next dev --turbo",
    "format": "biome format --write ./src",
    "lint": "biome check ./src",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "start": "next start"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "gray-matter": "^4.0.3",
    "html-react-parser": "^6.1.3",
    "lodash": "^4.18.1",
    "marked": "^18.0.5",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reframe.js": "^4.0.2",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
