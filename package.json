{
  "name": "exto-nextjs",
  "version": "0.1.0",
  "description": "A Stackbit Exto theme built with Next.js",
  "license": "MIT",
  "scripts": {
    "build": "NODE_OPTIONS=--openssl-legacy-provider next build && next export",
    "dev": "NODE_OPTIONS=--openssl-legacy-provider next dev",
    "develop": "next dev",
    "fetch": "sourcebit fetch",
    "format": "prettier --write '**/*.{js,jsx}'",
    "lint": "next lint",
    "prepare": "husky",
    "start": "next start"
  },
  "dependencies": {
    "babel-runtime": "^6.26.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint-config-next": "^12.3.7",
    "html-react-parser": "^6.0.1",
    "lodash": "^4.18.1",
    "marked": "^18.0.3",
    "next": "^12.3.7",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-helmet": "^6.1.0",
    "reframe.js": "^4.0.2",
    "sass": "^1.99.0",
    "sourcebit": "^0.11.1",
    "sourcebit-source-filesystem": "^0.2.0",
    "sourcebit-target-next": "^0.8.3",
    "webpack": "^5.106.2"
  },
  "devDependencies": {
    "@types/react": "^17.0.92",
    "@types/react-dom": "^17.0.26",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
