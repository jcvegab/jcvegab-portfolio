---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Seo from '@/components/Seo.astro';
import PageRenderer from '@/components/PageRenderer';
import {
  getAllPagePaths,
  getAllPagesData,
  getGlobalConfig,
  getPageDataBySlug,
} from '@/utils/content';

export async function getStaticPaths() {
  const paths = getAllPagePaths();
  return paths
    .filter((p) => p !== '/')
    .map((p) => ({
      params: { slug: p.replace(/^\//, '') },
    }));
}

const { slug } = Astro.params;
const slugPath = `/${slug}`;
const data = getPageDataBySlug(slugPath);

if (!data) {
  return new Response('Not Found', { status: 404 });
}

const config = getGlobalConfig();
const { seo } = data.page;

const metadata = data.page.__metadata as { modelName: string };
const modelName = metadata.modelName;

let projects: import('@/types').Page[] | undefined;
let posts: import('@/types').Page[] | undefined;

if (modelName === 'portfolio' || modelName === 'blog' || modelName === 'advanced') {
  const allPages = getAllPagesData();
  if (modelName === 'portfolio') {
    projects = allPages
      .filter((p) => p.page.__metadata?.modelName === 'project')
      .map((p) => p.page);
  } else if (modelName === 'blog') {
    posts = allPages
      .filter((p) => p.page.__metadata?.modelName === 'post')
      .map((p) => p.page);
  } else if (modelName === 'advanced') {
    projects = allPages
      .filter((p) => p.page.__metadata?.modelName === 'project')
      .map((p) => p.page);
    posts = allPages
      .filter((p) => p.page.__metadata?.modelName === 'post')
      .map((p) => p.page);
  }
}
---

<BaseLayout favicon={config?.favicon}>
  <Seo slot="head"
    title={seo?.title}
    description={seo?.description}
    robots={seo?.robots}
    extra={seo?.extra}
    domain={config?.domain}
  />

  <PageRenderer client:load data={data} posts={posts} projects={projects} currentPath={slugPath} />
</BaseLayout>
